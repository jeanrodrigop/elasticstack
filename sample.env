###############################################################################
# Elastic Stack — central configuration                                       #
#                                                                             #
# Copy this file to `.env` and adjust the values:                            #
#     cp sample.env .env                                                       #
#                                                                             #
# Docker Compose loads `.env` automatically. Never commit your real `.env`.  #
###############################################################################

# =============================================================================
# Global
# =============================================================================
# Project name — prefixes every container, network and volume created.
COMPOSE_PROJECT_NAME=elastic-stack

# Elastic Stack version. Applies to ALL images (ES, Kibana, Logstash, APM,
# Elastic Agent and every Beat) so the whole stack stays in lock-step.
# Pick the version you want to run: https://www.docker.elastic.co
STACK_VERSION=9.4.2

# Elasticsearch cluster name.
CLUSTER_NAME=elastic-stack

# License type: `basic` (free, default) or `trial` (30-day full features).
LICENSE=basic

# Timezone applied to every container (affects log timestamps).
TIMEZONE=UTC

# =============================================================================
# Elasticsearch
# =============================================================================
# Password for the built-in `elastic` superuser. CHANGE THIS.
# Use letters/numbers only to avoid escaping issues in healthchecks.
ELASTIC_PASSWORD=changeme

# Host port published for the Elasticsearch HTTP API (container is always 9200).
ES_PORT=9200

# Hard memory limit for the container. Should be ~2x the JVM heap below.
ES_MEM_LIMIT=2g

# JVM heap (sets both -Xms and -Xmx). Rule of thumb: 50% of ES_MEM_LIMIT,
# never above ~31g. 1g is fine for a homelab / small production node.
ES_JAVA_HEAP=1g

# CPU limit (number of cores the container may use).
ES_CPU_LIMIT=2

# =============================================================================
# Kibana
# =============================================================================
# Password for the built-in `kibana_system` user. The `setup` service applies
# this to Elasticsearch on first boot; Kibana then logs in with it. CHANGE THIS.
KIBANA_PASSWORD=changeme

# Host port published for the Kibana UI (container is always 5601).
KIBANA_PORT=5601

# Container memory / CPU limits.
KIBANA_MEM_LIMIT=1g
KIBANA_CPU_LIMIT=2

# 32+ character secret used to encrypt Fleet/alerting/reporting saved objects.
# MUST be set and MUST stay stable, otherwise Fleet & saved objects break.
# Generate one with:  openssl rand -hex 32
KIBANA_ENCRYPTION_KEY=change_me_to_a_random_32_char_minimum_string

# =============================================================================
# Fleet  (used by compose.agent.yaml)
# =============================================================================
# Internal URL agents use to reach Fleet Server (service name on the network).
FLEET_SERVER_HOST=fleet-server

# Host port published for Fleet Server (container is always 8220).
FLEET_SERVER_PORT=8220

# Container memory / CPU limits for Fleet Server.
FLEET_SERVER_MEM_LIMIT=1g
FLEET_SERVER_CPU_LIMIT=1

# =============================================================================
# Elastic Agent  (used by compose.agent.yaml)  — DEFAULT data shipper
# =============================================================================
# Name of the Fleet agent policy the monitoring agent enrolls into. This policy
# is pre-created in Kibana (see configs/kibana/kibana.yml) with the System and
# Docker integrations already attached.
AGENT_POLICY_NAME=Elastic Agent Observability

# Container memory / CPU limits.
AGENT_MEM_LIMIT=1g
AGENT_CPU_LIMIT=1

# =============================================================================
# Logstash  (used by compose.logstash.yaml)
# =============================================================================
# Beats input port (Filebeat/Elastic Agent -> Logstash).
LOGSTASH_BEATS_PORT=5044
# Raw TCP input port (apps -> Logstash).
LOGSTASH_TCP_PORT=5000
# Monitoring API port.
LOGSTASH_API_PORT=9600
# JVM heap and container limits.
LS_JAVA_HEAP=512m
LOGSTASH_MEM_LIMIT=1g
LOGSTASH_CPU_LIMIT=1

# =============================================================================
# APM  (used by compose.apm.yaml)
# =============================================================================
# Host port published for the APM Server intake API (container is always 8200).
APM_PORT=8200
# Secret token applications must send to publish APM data. Empty = no auth.
APM_SECRET_TOKEN=changeme_apm_token
# Container memory / CPU limits.
APM_MEM_LIMIT=1g
APM_CPU_LIMIT=1

# =============================================================================
# Legacy Beats  (optional fallback modules — Elastic Agent is preferred)
# =============================================================================
# Each Beat reads its own config file from ./configs/<beat>/<beat>.yml and ships
# straight to the core Elasticsearch using ELASTIC_PASSWORD above.

# Filebeat — container log collection.
FILEBEAT_CONFIG=./configs/filebeat/filebeat.yml

# Metricbeat — system & Docker metrics.
METRICBEAT_CONFIG=./configs/metricbeat/metricbeat.yml

# Auditbeat — host audit / file-integrity monitoring.
AUDITBEAT_CONFIG=./configs/auditbeat/auditbeat.yml

# Heartbeat — uptime / synthetic monitoring.
HEARTBEAT_CONFIG=./configs/heartbeat/heartbeat.yml
