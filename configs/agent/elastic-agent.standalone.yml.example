# =============================================================================
# Standalone Elastic Agent — EXAMPLE (not used by the default Fleet setup).
# See README.md in this folder for how to enable it.
# =============================================================================

outputs:
  default:
    type: elasticsearch
    hosts: ["http://elasticsearch:9200"]
    username: "elastic"
    password: "${ELASTIC_PASSWORD}"

inputs:
  # Host metrics (System integration, standalone form)
  - type: system/metrics
    id: system-metrics
    data_stream.namespace: default
    streams:
      - metricset: cpu
        data_stream.dataset: system.cpu
      - metricset: memory
        data_stream.dataset: system.memory
      - metricset: network
        data_stream.dataset: system.network
      - metricset: filesystem
        data_stream.dataset: system.filesystem

  # Container logs
  - type: filestream
    id: container-logs
    data_stream.namespace: default
    streams:
      - data_stream.dataset: docker.container_logs
        paths:
          - /var/lib/docker/containers/*/*.log

agent:
  monitoring:
    enabled: true
    logs: true
    metrics: true
